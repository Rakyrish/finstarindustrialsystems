# ──────────────────────────────────────────────────────────────────────────────
# FINSTAR Industrial Systems — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Node.js / Next.js ────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ── Python / Django ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
.venv/
*.egg-info/
dist/
staticfiles/
db.sqlite3
db.sqlite3-journal

# ── Environment Variables ────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep the example file
!.env.example

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Testing ──────────────────────────────────────────────────────────────────
/coverage
htmlcov/
.coverage
.pytest_cache/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Deployment ───────────────────────────────────────────────────────────────
.vercel
