# # ── Django ───────────────────────────────────────────────────────────────────
# # Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=change-me-to-a-random-50-char-string
# DEBUG=False

# # ── PostgreSQL Database ──────────────────────────────────────────────────────
# DB_NAME=finstar_db
# DB_USER=finstar_user
# DB_PASSWORD=change-me-strong-password
# DB_HOST=db
# DB_PORT=5432

# # ── Security ─────────────────────────────────────────────────────────────────
# ALLOWED_HOSTS=finstarindustrials.com,www.finstarindustrials.com,localhost,backend
# CORS_ALLOWED_ORIGINS=https://finstarindustrials.com,https://www.finstarindustrials.com
# CSRF_TRUSTED_ORIGINS=https://finstarindustrials.com,https://www.finstarindustrials.com

# # ── Frontend URLs ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://finstarindustrials.com/
# NEXT_PUBLIC_BASE_URL=https://finstarindustrials.com

# # ── Cloudinary (Image Storage) ───────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# # ── AI Services ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key

# # ── SSL (Let's Encrypt) ─────────────────────────────────────────────────────
# SSL_EMAIL=info@finstarindustrials.com
# SSL_STAGING=0

# # ── Gunicorn (Optional Tuning) ──────────────────────────────────────────────
# # GUNICORN_WORKERS=4
# # GUNICORN_THREADS=2
# # GUNICORN_TIMEOUT=120
