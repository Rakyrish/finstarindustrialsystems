# ──────────────────────────────────────────────────────────────────────────────
# Backend .dockerignore — Prevents sending unnecessary files to build context
# ──────────────────────────────────────────────────────────────────────────────

# Virtual environment (reinstalled in Docker)
venv/
env/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment (injected via docker-compose)
.env
.env.*

# Version control
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Django
*.log
logs/
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Tests
htmlcov/
.coverage
.pytest_cache/

# Misc
*.md
Dockerfile
=1.30
